# EditorConfig (https://editorconfig.org): keep whitespace consistent
# across editors. Mirrors the line-ending policy in .gitattributes.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yaml,yml,toml,json,md}]
indent_size = 2

# Makefiles require literal tabs in recipe lines.
[Makefile]
indent_style = tab

# Markdown uses trailing whitespace for hard line breaks.
[*.md]
trim_trailing_whitespace = false
