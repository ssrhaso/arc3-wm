# Copy to .env and fill in. .env is gitignored.
# arc_agi.base auto-loads .env (and .env.example as fallback) at import time
# via python-dotenv with dotenv_path=".env" — so the file must be at CWD when
# arc_agi is imported.

# ARC-AGI-3 API key from https://three.arcprize.org
ARC_API_KEY=

# Operation mode for arc_agi.Arcade. Verified by inspecting arc_agi.base:
#   _parse_operation_mode_from_env() lowercases and matches one of
#   {"normal", "online", "offline", "competition"}.
# OFFLINE = local-only, requires environment_files/ already populated
#           (use NORMAL once to cache, then switch to OFFLINE).
# NORMAL  = downloads game from API on first make(), caches, runs locally.
# ONLINE  = remote wrapper, every step is an API call; rate-limited.
OPERATION_MODE=offline

# Where Arcade scans for metadata.json (one per game). Default "environment_files".
ENVIRONMENTS_DIR=environment_files

# Recording output dir (used when save_recording=True on make()).
RECORDINGS_DIR=recordings

# Override API base URL only if Haso says so.
# ARC_BASE_URL=https://three.arcprize.org
